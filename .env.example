# Azure AD / MSAL 配置
MSAL_CLIENT_ID=your-azure-ad-client-id
AZURE_TENANT_ID=your-azure-ad-tenant-id

# 前端配置
FRONTEND_REDIRECT_URI=http://localhost:3500
BACKEND_URL=http://localhost:8765

# 后端 CORS 允许的来源（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:3500,http://127.0.0.1:3500

# 后端 / Foundry 配置
FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-account.services.ai.azure.com/api/projects/your-foundry-project

# Agent 定义
AGENT_MODEL=gpt-4.1-mini
AGENT_REASONING_EFFORT=medium
AGENT_NAME=FoundryAtlassianAgent

# MCP 工具配置
MCP_TOOL_SERVER_NAME=mcp-atlassian
MCP_TOOL_SERVER_URL=https://your-mcp-server.azurecontainerapps.io/mcp
MCP_PROJECT_CONNECTION_ID=your-mcp-project-connection-id
MCP_OAUTH_CLIENT_ID=your-mcp-oauth-client-id
MCP_OAUTH_CLIENT_SECRET=your-mcp-oauth-client-secret